# ==========================================
# Airtable Settings
# ==========================================
# API Token (empieza con pat...)
AIRTABLE_TOKEN=

# Base ID (empieza con app...)
AIRTABLE_BASE_ID=

# Nombres de las tablas (opcional, estos son los defaults)
AIRTABLE_PROJECTS_TABLE=projects
AIRTABLE_AUTH_TABLE=auth
AIRTABLE_CRM_TABLE=crm
AIRTABLE_BLOG_TABLE=blog

# Para entorno local en Vite (Opcional, solo si quieres acceso directo en dev)
VITE_AIRTABLE_TOKEN=
VITE_AIRTABLE_BASE_ID=
VITE_AIRTABLE_PROJECTS_TABLE=projects

# ==========================================
# Bolten CRM Settings
# ==========================================
# API Key generada en Bolten (Bearer token)
BOLTEN_API_KEY=

# Project ID en Bolten (UUID)
BOLTEN_PROJECT_ID=

# ==========================================
# Authentication & Sessions
# ==========================================
# Secreto para firmar cookies de sesión en el admin (32 caracteres o más)
SESSION_SECRET=your_super_secret_session_key_here

# ==========================================
# Local Development & Scripts
# ==========================================
# Si necesitas probar/construir credenciales encriptadas para JSON
PROJECT_CRED_PASSPHRASE=
ALLOW_PROJECT_ACCESS_CREDS=true